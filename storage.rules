rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function listAdminIds(listId) {
      let list = firestore.get(/databases/(default)/documents/lists/$(listId));
      return list == null ? [] : list.data.adminIds;
    }

    function isListAdmin(listId) {
      return request.auth != null && request.auth.uid in listAdminIds(listId);
    }

    match /lists/{listId}/gifts/{giftId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isListAdmin(listId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isListAdmin(listId);
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
