rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getList(listId) {
      return get(/databases/$(database)/documents/lists/$(listId)).data;
    }

    function isListAdmin(listId) {
      return request.auth != null && request.auth.uid in getList(listId).adminIds;
    }

    match /lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isListAdmin(listId);
    }

    match /lists/{listId}/gifts/{giftId} {
      allow read: if true;
      allow create, delete: if isListAdmin(listId);
      // Allow public updates for reservations (status, reservedBy, etc.)
      // Full enforcement of reservation tokens requires Cloud Functions.
      allow update: if isListAdmin(listId) || true;
    }
  }
}
