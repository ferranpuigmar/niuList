rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getList(listId) {
      return get(/databases/$(database)/documents/lists/$(listId)).data;
    }

    function isListAdmin(listId) {
      return request.auth != null && request.auth.uid in getList(listId).adminIds;
    }

    match /lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isListAdmin(listId);
    }

    match /lists/{listId}/gifts/{giftId} {
      allow read: if true;
      allow create, delete: if isListAdmin(listId);
      // Only admins write directly. Visitor reservation actions (reserve /
      // cancel / mark-bought) go through Cloud Functions, which use the Admin
      // SDK and validate ownership server-side, so no public write is allowed.
      allow update: if isListAdmin(listId);
    }
  }
}
